# ----- Database (off-chain cache) -----
DATABASE_URL="postgresql://user:pass@localhost:5432/predmarket"

# ----- Chain / deploy -----
# Deployer wallet (also the contract owner + admin). NEVER commit the real key.
DEPLOYER_PRIVATE_KEY="0x..."
# Server-side RPC (event listener + server reads). Defaults to the chain's public RPC.
RPC_URL="https://sepolia.base.org"
# Optional: contract verification
ETHERSCAN_API_KEY=""

# ----- Public (exposed to the browser) -----
NEXT_PUBLIC_CONTRACT_ADDRESS="0x..."
NEXT_PUBLIC_USDC_ADDRESS="0x..."
# 84532 = Base Sepolia · 80002 = Polygon Amoy · 31337 = local hardhat
NEXT_PUBLIC_CHAIN_ID="84532"
NEXT_PUBLIC_RPC_URL="https://sepolia.base.org"
# Admin wallet (matches DEPLOYER address). Lowercase or checksummed both work.
NEXT_PUBLIC_ADMIN_ADDRESS="0x..."
# Empty = same origin as the custom server (recommended for local dev).
NEXT_PUBLIC_SOCKET_URL=""
# WalletConnect Cloud project id (https://cloud.walletconnect.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=""

# ----- Fees -----
TREASURY_ADDRESS="0x..."          # fee collection wallet
FEE_BPS="100"                     # basis points: 100 = 1%, 0 = disabled, max 500

# ----- White-label branding (all optional; sensible defaults applied) -----
TENANT_NAME="PredictX"
TENANT_LOGO_URL=""
TENANT_FAVICON_URL=""
TENANT_PRIMARY="#7b6fff"
TENANT_YES_COLOR="#22c55e"
TENANT_NO_COLOR="#ef4444"
TENANT_SUPPORT_URL=""
